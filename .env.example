# Copia questo file in .env.local (in locale) e imposta le variabili anche su Vercel.

# Da Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client
GOOGLE_CLIENT_ID=xxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# URL pubblico dell'app. In locale: http://localhost:3000
# Su Vercel: https://tua-app.vercel.app
APP_URL=http://localhost:3000
