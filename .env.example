# Copia questo file in .env.local (in locale) e imposta le variabili anche su Vercel.

# Da dev.fitbit.com → la tua app
FITBIT_CLIENT_ID=xxxxxx
FITBIT_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# URL pubblico dell'app. In locale: http://localhost:3000
# Su Vercel: https://tua-app.vercel.app
APP_URL=http://localhost:3000
